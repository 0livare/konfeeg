{
  "name": "konfeeg",
  "version": "0.0.3",
  "description": "Build a validated, strongly-typed config object, and use it everywhere.",
  "author": "Zach Olivare <https://github.com/0livare>",
  "license": "ISC",
  "repository": "https://github.com/0livare/konfeeg",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest --run",
    "pub": "npx bumpp && pnpm publish"
  },
  "nx": {
    "targets": {
      "types": {},
      "format": {},
      "lint": {}
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:default",
    "tsdown": "^0.22.2",
    "typescript": "catalog:default",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "environment",
    "config",
    "configuration",
    "typescript",
    "type-safe",
    "validation",
    "browser",
    "node"
  ]
}
